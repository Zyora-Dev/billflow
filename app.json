{
  "expo": {
    "name": "mobile",
    "slug": "mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/billflow.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/billflow.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a1a40"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.spectra.billflow",
      "versionCode": 2,
      "adaptiveIcon": {
        "foregroundImage": "./assets/billflow.png",
        "backgroundColor": "#1a1a40"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      "@react-native-community/datetimepicker",
      [
        "expo-notifications",
        {
          "color": "#0EA5E9",
          "defaultChannel": "default"
        }
      ]
    ]
  }
}
